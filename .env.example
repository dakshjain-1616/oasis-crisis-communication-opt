# ─────────────────────────────────────────────────────────────
# OASIS Crisis Communication Optimizer — Environment Variables
# Copy this file to .env and fill in your values.
# Without any API key set the app runs in mock/dry-run mode.
# ─────────────────────────────────────────────────────────────

# ── API keys ──────────────────────────────────────────────────
# OpenAI API key — enables live LLM-powered agent mode
# Leave blank to run in mock mode (no API calls, fully local)
OPENAI_API_KEY=

# OpenRouter API key — alternative to OPENAI_API_KEY
# Supports the latest open-weight and proprietary models
OPENROUTER_API_KEY=

# ── Model selection ───────────────────────────────────────────
# LLM model for public/citizen agents (live mode only)
# Examples: openai/gpt-5.4-mini, mistralai/mistral-small-2603
AGENT_MODEL=openai/gpt-5.4-mini

# LLM model for the government/authority agent (live mode only)
GOV_MODEL=openai/gpt-5.4-mini

# ── Simulation defaults ───────────────────────────────────────
# Number of public citizen agents in each simulation run
NUM_AGENTS=30

# Number of simulation timesteps per run
NUM_TIMESTEPS=20

# Number of misinformation agents injecting false content
NUM_MISINFO_AGENTS=5

# Random seed for reproducible results (integer)
RANDOM_SEED=42

# ── Output ────────────────────────────────────────────────────
# Directory where CSV, PNG, JSON, and HTML reports are saved
OUTPUT_DIR=outputs

# ── Gradio UI server ──────────────────────────────────────────
# TCP port the Gradio web interface listens on
GRADIO_PORT=7860

# Host/IP the Gradio server binds to (0.0.0.0 = all interfaces)
GRADIO_HOST=0.0.0.0

# ── Runtime flags ─────────────────────────────────────────────
# Set to 1 to force mock mode even when API keys are present
# Useful for CI, demos, and offline development
FORCE_MOCK_MODE=0

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
